{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Packet",
  "type": "object",
  "required": [
    "task_id",
    "target",
    "inputs",
    "artifacts",
    "meta"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "skill",
            "workflow"
          ]
        }
      },
      "additionalProperties": true
    },
    "inputs": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "object"
        },
        "trace": {
          "type": "object"
        },
        "final_output": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "name"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "content": {}
        },
        "additionalProperties": true
      }
    },
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
